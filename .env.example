# Copy this file to .env.local for local development.
# Get these values from: Supabase dashboard → your project → Settings → API

# Your Supabase project URL (safe to expose — used in client + server)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"

# Anon/public key (safe to expose — for client-side, read-only queries)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service role secret key — SERVER ONLY, never commit or expose to browser
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
